# BM2R — règles serveur (o2switch / Apache)

RewriteEngine On

# 1. www -> non-www (en HTTPS)
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://%1%{REQUEST_URI} [L,R=301]

# 2. Forcer le HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 3. URLs propres : rediriger /index.html (ou /index) vers la racine
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [L,R=301]

# 4. URLs propres : rediriger /page.html vers /page (requête directe uniquement)
RewriteCond %{THE_REQUEST} \s/+([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [L,R=301]

# 5. Servir /page via page.html en interne (sans redirection ni boucle)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 6. Cache : HTML/CSS/JS revalides a chaque visite (304 si inchange -> maj immediate apres deploiement)
#    Images/polices en cache long (elles changent de nom quand elles changent).
<IfModule mod_headers.c>
  <FilesMatch "\.(html|css|js)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  <FilesMatch "\.(webp|jpe?g|png|gif|svg|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
